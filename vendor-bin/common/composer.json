{
    "require-dev": {
        "php": ">=8.2",
        "ergebnis/composer-normalize": "^2.51",
        "guanguans/monorepo-builder-worker": "^3.2",
        "laravel/framework": "^11.51 || ^12.0 || ^13.0",
        "symplify/rule-doc-generator": "^12.2"
    },
    "conflict": {
        "laravel/framework": ">=12.0"
    },
    "suggest": {
        "canvural/larastan-strict-rules": "php > 8.2",
        "larastan/larastan": "php > 8.2",
        "mrpunyapal/pest-annotator-plugin": "php > 8.2"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "theofidry/composer-inheritance-plugin": false,
            "wikimedia/composer-merge-plugin": false
        },
        "sort-packages": true
    }
}
